{
  "name": "@barissozen/csns",
  "version": "0.9.8",
  "description": "CSNS — Code-aware Self-correcting Never-forgetting System",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator/index.d.ts",
      "import": "./dist/orchestrator/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./brief": {
      "types": "./dist/brief/index.d.ts",
      "import": "./dist/brief/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    }
  },
  "bin": {
    "csns": "dist/bin/csns.js",
    "mandosi": "dist/bin/csns.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "init": "tsx src/bin/pc.ts init",
    "run:orchestrator": "tsx src/bin/pc.ts run",
    "status": "tsx src/bin/pc.ts status",
    "log": "tsx src/bin/pc.ts log",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "orchestration",
    "memory",
    "audit",
    "reverse-engineering",
    "agent",
    "llm",
    "csns"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BarisSozen/project-consciousness.git"
  },
  "author": "Baris Sozen",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.4.0",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.0",
    "zod": "^3.24.0"
  }
}
